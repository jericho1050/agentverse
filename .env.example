# AWS Bedrock (Claude AI via AWS credits)
# Option 1: Use AWS SSO profile (recommended)
AWS_PROFILE=your-sso-profile-name
AWS_REGION=us-east-1

# Option 2: Use explicit credentials (include session token for SSO)
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=... (required for SSO/temporary credentials)

# Hedera Platform Account (ECDSA key required)
HEDERA_OPERATOR_ID=0.0.xxxxx
HEDERA_OPERATOR_KEY=0x... (ECDSA private key in hex format)

# Hedera Network
NEXT_PUBLIC_NETWORK=testnet
NEXT_PUBLIC_AGENT_MODE=autonomous

# Agent Accounts (create 3 ECDSA accounts at https://portal.hedera.com)
AGENT_CODE_REVIEW_ACCOUNT_ID=0.0.xxxxx
AGENT_CODE_REVIEW_PRIVATE_KEY=0x...
AGENT_DATA_ANALYSIS_ACCOUNT_ID=0.0.xxxxx
AGENT_DATA_ANALYSIS_PRIVATE_KEY=0x...
AGENT_CONTENT_WRITER_ACCOUNT_ID=0.0.xxxxx
AGENT_CONTENT_WRITER_PRIVATE_KEY=0x...

# HCS Topic IDs (created by: npx tsx scripts/setup-topics.ts)
HCS_REGISTRY_TOPIC_ID=0.0.xxxxx
HCS_NEGOTIATION_TOPIC_ID=0.0.xxxxx
HCS_REPUTATION_TOPIC_ID=0.0.xxxxx

# HTS Token (created by: npx tsx scripts/create-token.ts)
AVT_TOKEN_ID=0.0.xxxxx

# Escrow Smart Contract (deployed by: npx hardhat run scripts/deploy-escrow.ts --network hedera_testnet)
ESCROW_CONTRACT_EVM_ADDRESS=0x...

# Mirror Node
MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com/api/v1
